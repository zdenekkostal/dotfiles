#!/usr/bin/env bash
# switch-theme: Centralized theme switcher for all tools
#
# Usage:
#   switch-theme dark <pack>    # Set dark theme to a pack (rose-pine, gruvbox, catppuccin)
#   switch-theme light <pack>   # Set light theme to a pack
#   switch-theme both <pack>    # Set both dark and light to the same pack
#   switch-theme apply          # Re-apply current theme based on OS appearance
#   switch-theme apply dark     # Force apply dark theme
#   switch-theme apply light    # Force apply light theme
#   switch-theme status         # Show current config
#
# On macOS, "apply" detects dark/light mode automatically.
# On Linux, "apply" defaults to dark unless specified.

set -euo pipefail

THEME_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/theme.conf"
THEME_PACKS_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/theme-packs"

# ─── Helpers ──────────────────────────────────────────────

die() { echo "error: $*" >&2; exit 1; }

# Read a value from theme.conf: get_conf <section> <key>
get_conf() {
  local section="$1" key="$2"
  awk -v section="$section" -v key="$key" '
    /^\[/ { current = $0; gsub(/[\[\]]/, "", current) }
    current == section && $1 == key && $2 == "=" { $1=""; $2=""; sub(/^ +/, ""); print; exit }
  ' "$THEME_CONF"
}

# Replace a value in theme.conf: set_conf <section> <key> <value>
set_conf() {
  local section="$1" key="$2" value="$3"
  local tmpfile
  tmpfile=$(mktemp)

  awk -v section="$section" -v key="$key" -v value="$value" '
    /^\[/ { current = $0; gsub(/[\[\]]/, "", current) }
    current == section && $1 == key { print key " = " value; next }
    { print }
  ' "$THEME_CONF" > "$tmpfile"
  mv "$tmpfile" "$THEME_CONF"
}

# Copy all values from a theme pack file into a section
apply_pack() {
  local section="$1" packfile="$2"
  [[ -f "$packfile" ]] || die "Theme pack not found: $packfile"
  while IFS=' = ' read -r key value; do
    [[ -z "$key" || "$key" == \#* ]] && continue
    set_conf "$section" "$key" "$value"
  done < "$packfile"
}

# Detect current OS appearance: returns "dark" or "light"
detect_mode() {
  if [[ "$(uname)" == "Darwin" ]]; then
    if [[ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" == "Dark" ]]; then
      echo "dark"
    else
      echo "light"
    fi
  else
    # Linux: default to dark
    echo "dark"
  fi
}

# ─── Apply functions ─────────────────────────────────────

apply_ghostty() {
  local dark_theme="$1" light_theme="$2"
  local config_file="${XDG_CONFIG_HOME:-$HOME/.config}/ghostty/config"
  [[ -f "$config_file" ]] || return 0

  # Update the theme line
  if grep -q "^theme = " "$config_file" 2>/dev/null; then
    local new_theme="dark:${dark_theme},light:${light_theme}"
    sed -i.bak "s|^theme = .*|theme = ${new_theme}|" "$config_file"
    rm -f "${config_file}.bak"
  fi
  echo "  ghostty: dark=${dark_theme}, light=${light_theme}"
}

apply_tmux() {
  local mode="$1" tmux_theme="$2"
  local theme_file="$HOME/.tmux/${tmux_theme}.conf"

  if [[ ! -f "$theme_file" ]]; then
    echo "  tmux: theme file not found: $theme_file (skipped)"
    return 0
  fi

  # Update tmux-dark-notify paths in tmux config
  local tmux_conf="$HOME/.tmux.conf"
  if [[ -f "$tmux_conf" ]]; then
    local dark_path light_path
    dark_path=$(get_conf "dark" "tmux")
    light_path=$(get_conf "light" "tmux")
    sed -i.bak "s|@dark-notify-theme-path-dark.*|@dark-notify-theme-path-dark \"$HOME/.tmux/${dark_path}.conf\"|" "$tmux_conf"
    sed -i.bak "s|@dark-notify-theme-path-light.*|@dark-notify-theme-path-light \"$HOME/.tmux/${light_path}.conf\"|" "$tmux_conf"
    rm -f "${tmux_conf}.bak"
  fi

  # Source the right theme for the current mode if tmux is running
  if command -v tmux &>/dev/null && tmux list-sessions &>/dev/null 2>&1; then
    tmux source-file "$theme_file" 2>/dev/null || true
  fi
  echo "  tmux: ${tmux_theme}"
}

apply_nvim() {
  local colorscheme="$1" background="$2" lualine_theme="$3"

  # Write a lua file that nvim reads on theme change
  local nvim_theme_file="${XDG_CONFIG_HOME:-$HOME/.config}/nvim/lua/current-theme.lua"
  cat > "$nvim_theme_file" <<EOF
-- Auto-generated by switch-theme. Do not edit manually.
return {
  colorscheme = "${colorscheme}",
  background = "${background}",
  lualine = "${lualine_theme}",
}
EOF

  # Send commands to all running nvim instances
  local applied=0
  for sock in /tmp/nvim.*/0 /run/user/*/nvim.*/0 ${XDG_RUNTIME_DIR:-/tmp}/nvim.*/0; do
    [[ -S "$sock" ]] || continue
    nvim --server "$sock" --remote-send \
      "<Cmd>set background=${background}<CR><Cmd>colorscheme ${colorscheme}<CR>" 2>/dev/null && ((applied++)) || true
  done

  echo "  nvim: colorscheme=${colorscheme}, bg=${background}, lualine=${lualine_theme} (${applied} instances updated)"
}

apply_bat() {
  local bat_theme="$1"
  local bat_config="${XDG_CONFIG_HOME:-$HOME/.config}/bat/config"
  [[ -f "$bat_config" ]] || return 0

  sed -i.bak "s|^--theme=.*|--theme=\"${bat_theme}\"|" "$bat_config"
  rm -f "${bat_config}.bak"
  echo "  bat: ${bat_theme}"
}

apply_delta() {
  # Delta reads from theme.conf via delta-pager at runtime, nothing to do here
  local delta_theme="$1"
  echo "  delta: ${delta_theme} (read dynamically)"
}

# ─── Main apply ──────────────────────────────────────────

do_apply() {
  local mode="${1:-$(detect_mode)}"
  echo "Applying ${mode} theme..."

  local ghostty_theme nvim_cs nvim_bg tmux_theme bat_theme delta_theme lualine_theme
  ghostty_theme=$(get_conf "$mode" "ghostty")
  nvim_cs=$(get_conf "$mode" "nvim_colorscheme")
  nvim_bg=$(get_conf "$mode" "nvim_background")
  tmux_theme=$(get_conf "$mode" "tmux")
  bat_theme=$(get_conf "$mode" "bat")
  delta_theme=$(get_conf "$mode" "delta")
  lualine_theme=$(get_conf "$mode" "lualine")

  apply_ghostty "$(get_conf dark ghostty)" "$(get_conf light ghostty)"
  apply_nvim "$nvim_cs" "$nvim_bg" "$lualine_theme"
  apply_tmux "$mode" "$tmux_theme"
  apply_bat "$bat_theme"
  apply_delta "$delta_theme"

  echo "Done."
}

# ─── Commands ────────────────────────────────────────────

cmd_set() {
  local variant="$1" pack="$2"

  if [[ "$variant" == "both" ]]; then
    cmd_set "dark" "$pack"
    cmd_set "light" "$pack"
    return
  fi

  local packfile="${THEME_PACKS_DIR}/${pack}.${variant}"
  [[ -f "$packfile" ]] || die "Theme pack not found: ${pack}.${variant}
Available packs: $(ls "$THEME_PACKS_DIR" | sed 's/\.\(dark\|light\)$//' | sort -u | tr '\n' ' ')"

  apply_pack "$variant" "$packfile"
  echo "Set ${variant} theme to ${pack}"
}

cmd_status() {
  echo "Current theme configuration (${THEME_CONF}):"
  echo ""
  echo "Dark mode:"
  echo "  ghostty:  $(get_conf dark ghostty)"
  echo "  nvim:     $(get_conf dark nvim_colorscheme) (bg: $(get_conf dark nvim_background))"
  echo "  tmux:     $(get_conf dark tmux)"
  echo "  bat:      $(get_conf dark bat)"
  echo "  delta:    $(get_conf dark delta)"
  echo "  lualine:  $(get_conf dark lualine)"
  echo ""
  echo "Light mode:"
  echo "  ghostty:  $(get_conf light ghostty)"
  echo "  nvim:     $(get_conf light nvim_colorscheme) (bg: $(get_conf light nvim_background))"
  echo "  tmux:     $(get_conf light tmux)"
  echo "  bat:      $(get_conf light bat)"
  echo "  delta:    $(get_conf light delta)"
  echo "  lualine:  $(get_conf light lualine)"
  echo ""
  echo "OS appearance: $(detect_mode)"
  echo ""
  echo "Available theme packs:"
  ls "$THEME_PACKS_DIR" | sed 's/\.\(dark\|light\)$//' | sort -u | while read -r p; do
    echo "  - $p"
  done
}

cmd_help() {
  cat <<'EOF'
switch-theme: Centralized theme switcher

Usage:
  switch-theme dark <pack>      Set dark theme pack (e.g. rose-pine, gruvbox)
  switch-theme light <pack>     Set light theme pack
  switch-theme both <pack>      Set both dark and light to same pack
  switch-theme apply [mode]     Apply current config (auto-detects dark/light)
  switch-theme status           Show current configuration
  switch-theme help             Show this help

Examples:
  switch-theme light gruvbox    # Use gruvbox for light mode
  switch-theme dark rose-pine   # Use rose-pine for dark mode
  switch-theme both catppuccin  # Use catppuccin for everything
  switch-theme apply            # Apply based on current OS appearance
  switch-theme apply dark       # Force dark theme
EOF
}

# ─── Entry point ─────────────────────────────────────────

[[ -f "$THEME_CONF" ]] || die "Theme config not found: $THEME_CONF"

case "${1:-help}" in
  dark|light|both)
    [[ -n "${2:-}" ]] || die "Usage: switch-theme $1 <pack>"
    cmd_set "$1" "$2"
    do_apply
    ;;
  apply)
    do_apply "${2:-}"
    ;;
  status)
    cmd_status
    ;;
  help|--help|-h)
    cmd_help
    ;;
  *)
    die "Unknown command: $1. Run 'switch-theme help' for usage."
    ;;
esac
