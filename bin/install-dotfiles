#!/usr/bin/env zsh

set -e

cd ~

#######################################
# 1. OS Detection & Variables
#######################################

IS_MACOS=false
IS_LINUX=false

case "$OSTYPE" in
  darwin*)  IS_MACOS=true ;;
  linux*)   IS_LINUX=true ;;
esac

BACKUP_DIR="$HOME/.dotfiles-backup/$(date +%Y%m%d)"
DOTFILES_DIR="$HOME/.dotfiles"

# Set Homebrew path (macOS only)
if [[ -d "/opt/homebrew/bin" ]]; then
  export PATH="/opt/homebrew/bin:$PATH"
fi

#######################################
# 2. Helper Functions
#######################################

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

install_package() {
  local pkg="$1"
  if $IS_MACOS; then
    brew install "$pkg"
  elif $IS_LINUX; then
    sudo apt-get install -y "$pkg"
  fi
}

# Interactive prompt for file conflicts
# Returns: 0=yes, 1=no, 2=all, 3=quit
OVERWRITE_ALL=false
prompt_overwrite() {
  local file="$1"

  if $OVERWRITE_ALL; then
    return 0
  fi

  echo ""
  echo "File already exists: $file"
  echo -n "Overwrite? [y]es / [n]o / [a]ll / [q]uit: "
  read -r response

  case "$response" in
    y|Y) return 0 ;;
    n|N) return 1 ;;
    a|A) OVERWRITE_ALL=true; return 0 ;;
    q|Q) echo "Aborting."; exit 1 ;;
    *) return 1 ;;
  esac
}

backup_file() {
  local file="$1"
  if [[ -e "$file" ]]; then
    mkdir -p "$BACKUP_DIR"
    cp -r "$file" "$BACKUP_DIR/"
    echo "Backed up: $file -> $BACKUP_DIR/"
  fi
}

#######################################
# 3. Xcode Command Line Tools (macOS only)
#######################################

# Must happen before any git use — bare macOS ships a git stub that
# prompts for CLT installation and blocks non-interactively.
if $IS_MACOS && ! xcode-select -p &>/dev/null; then
  echo "Installing Xcode Command Line Tools..."
  xcode-select --install
  echo "Waiting for Xcode CLT installation to complete..."
  until xcode-select -p &>/dev/null; do sleep 5; done
fi

#######################################
# 4. Homebrew Installation (macOS only)
#######################################

if $IS_MACOS && ! command_exists brew; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  # Re-add to PATH after installation
  if [[ -d "/opt/homebrew/bin" ]]; then
    export PATH="/opt/homebrew/bin:$PATH"
  fi
fi

#######################################
# 5. Dotfiles Checkout with Conflict Handling
#######################################

dotfiles() {
  git --git-dir="$HOME/.dotfiles/" --work-tree="$HOME" "$@"
}

# Clone if not exists
if [[ ! -d "$DOTFILES_DIR" ]]; then
  echo "Cloning dotfiles..."
  git clone --bare https://github.com/zdenekkostal/dotfiles.git "$DOTFILES_DIR"
fi

dotfiles config status.showUntrackedFiles no
dotfiles config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"

echo "Fetching latest dotfiles..."
dotfiles fetch origin

# Try checkout; on conflict, back up conflicting files and retry
echo "Checking out dotfiles..."
checkout_output=$(dotfiles checkout FETCH_HEAD 2>&1) || {
  conflicts=$(echo "$checkout_output" | grep "^\s" | awk '{print $1}')
  echo "The following files would be overwritten:"
  echo "$conflicts"
  echo ""

  for file in ${(f)conflicts}; do
    if prompt_overwrite "$file"; then
      backup_file "$HOME/$file"
      rm -rf "$HOME/$file"
    fi
  done

  dotfiles checkout FETCH_HEAD || {
    echo "Checkout completed with some skipped files."
  }
}

git config --global core.excludesFile ~/.gitignore_global

#######################################
# 6. Native Package Manager Dependencies
#######################################

echo "Installing native packages..."

if $IS_MACOS; then
  brew install git tmux gnupg coreutils sheldon mas zk miniserve tree nss TankerHQ/homebrew-repo/ruplacer remotemobprogramming/brew/mob ksdme/tap/ut jnsahaj/lumen/lumen tig mosh dlvhdr/formulae/diffnav
elif $IS_LINUX; then
  sudo apt-get update
  sudo apt-get install -y \
    git \
    tmux \
    gnupg \
    build-essential \
    pkg-config \
    libssl-dev \
    curl \
    wget \
    unzip \
    zsh \
    tig \
    mosh
fi

#######################################
# 7. Mise Installation & CLI Tools
#######################################

if ! command_exists mise; then
  echo "Installing mise..."
  curl -fsSL https://mise.run | sh
fi

# Add mise shims to PATH for this script session
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.local/share/mise/shims:$PATH"

echo "Installing CLI tools via mise..."
mise use --global \
  neovim@latest \
  fzf@latest \
  ripgrep@latest \
  fd@latest \
  bat@latest \
  jq@latest \
  delta@latest \
  starship@latest \
  glow@latest \
  difftastic@latest \
  awscli@latest \
  ast-grep@latest \
  television@latest \
  tlrc@latest \
  shellcheck@latest \
  mkcert@latest \
  gotestsum@latest \
  yamlfmt@latest

#######################################
# 8. Languages via Mise
#######################################

echo "Installing languages via mise..."
mise use --global \
  nodejs@lts \
  yarn@latest \
  golang@latest \
  python@latest \
  rust@latest

# Rust components
if command_exists rustup; then
  rustup component add clippy rustfmt rust-src
fi

# npm-backed tools — must come after Node is installed
mise use --global \
  npm:svgo@latest \
  npm:markdownlint-cli@latest

# yamllint — install via pip since Python is already available
mise exec python -- pip install --user yamllint

#######################################
# 9. Sheldon (Linux via Cargo)
#######################################

if $IS_LINUX && ! command_exists sheldon; then
  echo "Installing sheldon via cargo..."
  cargo install sheldon
fi

#######################################
# 10. macOS-specific Setup
#######################################

if $IS_MACOS; then
  echo "Installing macOS GUI applications..."
  brew install --cask \
    alacritty \
    ghostty \
    karabiner-elements \
    cleanshot \
    spotify \
    notion \
    choosy \
    keka \
    muzzle \
    pixelsnap \
    iina \
    handbrake \
    topnotch \
    steam \
    dictionaries \
    raycast \
    rancher \
    firefox@developer-edition \
    font-fira-code-nerd-font \
    font-hack-nerd-font \
    1password-cli \
    zed \
    claude \
    obsidian \
    figma \
    linear-linear \
    whatsapp \
    nikitabobko/tap/aerospace

  # Thanks https://github.com/mathiasbynens/dotfiles/blob/main/.macos
  echo "Configuring macOS defaults..."
  osascript -e 'tell application "System Preferences" to quit' 2>/dev/null || \
  osascript -e 'tell application "System Settings" to quit' 2>/dev/null || true

  defaults write -g InitialKeyRepeat -int 15
  defaults write -g KeyRepeat -int 2

  # Disable auto-correct
  defaults write -g NSAutomaticSpellingCorrectionEnabled -bool false

  # Disable accented characters popup
  defaults write -g ApplePressAndHoldEnabled -bool false

  # Disable the "Are you sure you want to open this application?" dialog
  defaults write com.apple.LaunchServices LSQuarantine -bool false

  # Disable applications being added to dock automatically
  defaults write com.apple.dock show-recents -bool false

  # Turn on tap to click
  defaults write com.apple.AppleMultitouchTrackpad Clicking -bool true

  # Enable thin strokes in Alacritty
  defaults write -g AppleFontSmoothing -int 0

  # Install keyboard layout
  if [[ ! -f "/Library/Keyboard Layouts/Czech_Programmers_0.2.keylayout" ]]; then
    echo "Installing keyboard layout..."
    sudo cp "$HOME/keyboard_layouts/Czech_Programmers_0.2.keylayout" "/Library/Keyboard Layouts/"
  fi

  # Install App Store applications if signed in
  if defaults read MobileMeAccounts Accounts 2>/dev/null | grep -q 'AccountID'; then
    echo "Installing App Store applications..."
    brew bundle install --file=brewfile_apps
  fi

fi

#######################################
# 11. Shell Plugins & Post-install
#######################################

echo "Installing shell plugins..."
mkdir -p ~/.config/sheldon
sheldon lock --update

if [[ ! -d "$HOME/.tmux/plugins/tpm" ]]; then
  echo "Installing Tmux plugin manager..."
  git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
  TMUX_PLUGIN_MANAGER_PATH="$HOME/.tmux/plugins/" ~/.tmux/plugins/tpm/bin/install_plugins
fi

#######################################
# 12. Neovim Dependencies
#######################################

echo "Installing Neovim packages and LSP dependencies..."

# Node-based tools
mise exec nodejs -- npm install -g \
  @fsouza/prettierd \
  eslint_d \
  typescript-language-server \
  typescript \
  vscode-langservers-extracted \
  @zed-industries/claude-code-acp

# Go tools
mise exec golang -- go install golang.org/x/tools/gopls@latest
mise exec golang -- go install github.com/go-delve/delve/cmd/dlv@latest
mise exec golang -- go install github.com/uber-go/mock/mockgen@latest
mise exec golang -- go install github.com/daixiang0/gci@latest


#######################################
# 13. Source Configuration
#######################################

echo "Sourcing dotfiles..."
[[ -f ~/.profile ]] && source ~/.profile
[[ -f ~/.zshrc ]] && source ~/.zshrc

# Set wallpaper (requires .zshrc sourced above for the wallpaper function)
if $IS_MACOS; then
  wallpaper "$HOME/wallpapers/gradiant.heic"
fi

echo ""
echo "Installation complete!"
