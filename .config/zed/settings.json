// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // "agent_servers": {
  //   "claude-code-acp": {
  //     "command": "claude-code-acp"
  //   }
  // },
  "session": {
    "trust_all_worktrees": true
  },
  "colorize_brackets": true,
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
    "hide_gitignore": false,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "relative_line_numbers": "disabled",
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "pi-acp": {
      "type": "registry",
    },
  },
  "context_servers": {
    "figma": {
      "enabled": false,
      "command": "npx",
      "args": ["-y", "mcp-remote", "http://127.0.0.1:3845/mcp"],
      "env": {},
    },
    "playwright": {
      "enabled": true,
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "env": {},
    },
    "mcp-server-github": {
      "enabled": false,
      "settings": {
        "github_personal_access_token": "",
      },
    },
    "echo-design-system": {
      "command": "npx",
      "args": ["@typeform/echo-mcp-server@1.0.2", "--stdio"],
      "env": null,
    },
    "browser-tools-context-server": {
      "settings": {
        "port": 3025,
        "host": "127.0.0.1",
      },
    },
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "dock": "right",
    "default_profile": "write",
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4",
    },
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-5-thinking-latest",
    },
  },
  "language_models": {
    "bedrock": {
      "authentication_method": "named_profile",
      "profile": "tools",
      // "region": "eu-west-1"
      "region": "us-east-1",
    },
  },
  "vim_mode": true,
  "ui_font_family": "FiraCode Nerd Font",
  "ui_font_size": 13,
  "buffer_font_family": "FiraCode Nerd Font",
  "buffer_font_size": 12,
  "theme": {
    "mode": "system",
    // "light": "Gruvbox Light Soft",
    "light": "Gruvbox Light",
    "dark": "Rosé Pine",
  },
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_file_finder": true,
    "enable_keep_preview_on_code_navigation": true,
  },
}
